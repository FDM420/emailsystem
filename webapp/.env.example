# Copy to .env for local dev (gitignored). In Railway, set these as service variables.

# MXroute API credentials
MXROUTE_SERVER=tuesday.mxrouting.net
MXROUTE_USERNAME=your-mxroute-username
MXROUTE_API_KEY=your-mxroute-api-key

# Portal login password (you choose this)
ADMIN_PASSWORD=change-me-to-a-strong-password

# Optional: secret for signing the auth cookie. If unset, a random one is used
# per boot (you'll just have to log in again after each restart).
SESSION_SECRET=

# PORT is provided automatically by Railway. For local dev it defaults to 3000.
